# Copy to env.production for docker-compose.prod.yml.
# Do not commit env.production.

APP_ENV=production

POSTGRES_DB=leadpilot
POSTGRES_USER=leadpilot
POSTGRES_PASSWORD=replace-with-managed-or-strong-local-password
REDIS_PASSWORD=replace-with-strong-redis-password

DATABASE_URL=postgresql+psycopg://leadpilot:replace-with-managed-or-strong-local-password@postgres:5432/leadpilot
REDIS_URL=redis://:replace-with-strong-redis-password@redis:6379/0

JWT_SECRET_KEY=replace-with-at-least-32-random-characters
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_SIMPLE_MODEL=gpt-4.1-mini
OPENAI_COMPLEX_MODEL=gpt-4.1
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

CORS_ORIGINS=https://your-frontend.vercel.app
TRUSTED_HOSTS=your-backend.railway.app,your-backend.onrender.com,localhost,127.0.0.1
LOG_LEVEL=INFO
GUNICORN_WORKERS=2
UPLOAD_DIR=/app/uploads

NEXT_PUBLIC_API_URL=https://your-backend.railway.app
