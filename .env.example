# Shared
APP_ENV=development

# Backend
DATABASE_URL=postgresql+psycopg://leadpilot:leadpilot@postgres:5432/leadpilot
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
CELERY_TASK_ALWAYS_EAGER=false
JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_ISSUER=leadpilot-ai
ACCESS_TOKEN_EXPIRE_MINUTES=1440
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_SIMPLE_MODEL=gpt-4.1-mini
OPENAI_COMPLEX_MODEL=gpt-4.1
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
CORS_ORIGINS=http://localhost:3000
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_BYTES=10485760
RATE_LIMIT_AUTH_PER_MINUTE=20
RATE_LIMIT_AI_PER_MINUTE=60
RATE_LIMIT_BILLING_PER_MINUTE=60
RATE_LIMIT_PUBLIC_PER_MINUTE=120
FAILED_LOGIN_LOCK_THRESHOLD=5
FAILED_LOGIN_LOCK_MINUTES=15

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
