APP_ENV=production
DATABASE_URL=postgresql+psycopg://user:password@host:5432/leadpilot
REDIS_URL=rediss://default:password@host:6379/0
JWT_SECRET_KEY=replace-with-at-least-32-random-characters
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_SIMPLE_MODEL=gpt-4.1-mini
OPENAI_COMPLEX_MODEL=gpt-4.1
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
CORS_ORIGINS=https://your-frontend.vercel.app
TRUSTED_HOSTS=your-backend.railway.app,your-backend.onrender.com
LOG_LEVEL=INFO
GUNICORN_WORKERS=2
UPLOAD_DIR=/app/uploads
